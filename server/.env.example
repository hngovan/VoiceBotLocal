# VoiceBotLocal - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
DAILY_ROOM_URL=  # Optional: leave empty to create a new room

# Whisper (STT) - Runs locally, no API key required.
# Model options: tiny, base, small, medium, large (larger = more precise, heavier)
# For Vietnamese: use at least "small". "base" does not recognize Vietnamese well.
#OPENAI_API_KEY=
OPENAI_MODEL=small
# Language code for Whisper (vi = Vietnamese, en = English, auto = auto-detect)
WHISPER_LANGUAGE=vi
# P99 latency từ khi user ngừng nói đến khi có transcript (giây)
# Đo thực tế từ log "WhisperSTTService processing time". Tăng nếu hay bị transcript rỗng.
WHISPER_TTFS_P99=1.5

# Ollama (LLM)
OLLAMA_MODEL=qwen2.5:7b
# GPU: OLLAMA_NUM_GPU phải set làm biến môi trường HỆ THỐNG trước khi khởi động Ollama server,
# không phải trong file .env này. Ví dụ trên PowerShell:
#   $env:OLLAMA_NUM_GPU="-1"; ollama serve   (-1 = tất cả GPU, 0 = CPU only)

# VieNeu-TTS (TTS) - Vietnamese local TTS
# Install: pip install vieneu
# Windows CPU: pip install vieneu --extra-index-url https://pnnbao97.github.io/llama-cpp-python-v0.3.16/cpu/
#
# VIENEU_MODE options:
#   standard   — GGUF llama-cpp, CPU (default, chậm hơn)
#   turbo      — GGUF llama-cpp, CPU (nhanh hơn, khuyên dùng khi không có GPU)
#   turbo_gpu  — PyTorch/LMDeploy, cần CUDA GPU
VIENEU_MODE=turbo
# Voice index (0 = giọng mặc định, list voices: tts.list_preset_voices())
#   ┌───────┬────────────┬───────────┬──────────┐
#   │ Index │   Giọng    │ Giới tính │   Vùng   │
#   ├───────┼────────────┼───────────┼──────────┤
#   │ 0     │ Bích Ngọc  │ Nữ        │ Miền Bắc │
#   ├───────┼────────────┼───────────┼──────────┤
#   │ 1     │ Phạm Tuyên │ Nam       │ Miền Bắc │
#   ├───────┼────────────┼───────────┼──────────┤
#   │ 2     │ Thục Đoan  │ Nữ        │ Miền Nam │
#   ├───────┼────────────┼───────────┼──────────┤
#   │ 3     │ Xuân Vĩnh  │ Nam       │ Miền Nam |
VIENEU_VOICE_INDEX=0


# Tool Web Search
OLLAMA_API_KEY=
